# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
AZURE_PROJECT_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<foundry-account>/projects/<project-name>

# Agent model
AZURE_AI_MODEL_DEPLOYMENT_NAME=<model-deployment-name>
AZURE_OPENAI_ENDPOINT=https://<azure-openai-resource>.cognitiveservices.azure.com
AZURE_OPENAI_API_VERSION=2024-05-01-preview
EMBEDDING_MODEL=text-embed-3-large

# Azure AI Search
SEARCH_ENDPOINT=https://{search-name}.search.windows.net
SEARCH_INDEX_NAME=insurance-knowledge
KNOWLEDGE_SOURCE_NAME=insurance-knowledge-source
KNOWLEDGE_BASE_NAME=insurance-knowledge-base
SEARCH_TOP_K=5
SEARCH_VECTOR_DIM=3072
EMBEDDING_BATCH_SIZE=16
UPLOAD_BATCH_SIZE=100
MAX_PARALLEL_UPLOADS=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# MCP tool (Foundry IQ knowledge base)
# If not set, MCP endpoint is derived from SEARCH_ENDPOINT and KNOWLEDGE_BASE_NAME.
MCP_SERVER_URL=
MCP_SERVER_LABEL=foundry-iq
MCP_CONNECTION_NAME=foundry-iq-connection
MCP_PROJECT_CONNECTION_ID=foundry-iq-connection
MCP_REQUIRE_APPROVAL=always
MCP_ALLOWED_TOOLS=knowledge_base_retrieve
MCP_AUTO_APPROVE=true
INSURANCE_AGENT_NAME=pb-insurance-agent

# Telemetry (optional)
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=<instrumentation-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<application-id>
OTEL_SERVICE_NAME=pb-insurance-agent
OTEL_SERVICE_VERSION=0.1.0
OTEL_CAPTURE_MESSAGE_CONTENT=true
