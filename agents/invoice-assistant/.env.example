# Azure AI Projects
AZURE_PROJECTS_ENDPOINT=https://{your-foundry-project}.ai.azure.com

# Azure OpenAI (Responses API)
AZURE_OPENAI_ENDPOINT=https://{your-azure-openai-resource}.cognitiveservices.azure.com
AZURE_OPENAI_MODEL=<YOUR_MODEL_DEPLOYMENT_NAME>
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# LLM-as-judge (Foundry evals API)
# Use a deployment in your Foundry project for judge
AZURE_AI_MODEL_DEPLOYMENT_NAME=<YOUR_JUDGE_MODEL_DEPLOYMENT_NAME>

# Azure Monitor / App Insights
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=YOUR_KEY;IngestionEndpoint=https://REGION.in.applicationinsights.azure.com/;LiveEndpoint=https://REGION.livediagnostics.monitor.azure.com/;ApplicationId=YOUR_APP_ID
OTEL_CAPTURE_MESSAGE_CONTENT=true


# Agent settings
INVOICE_DATASET_NAME=invoices-dataset
INVOICE_VECTORSTORE_NAME=invoices-vectorstore
INVOICE_AGENT_NAME=invoice-assistant
INVOICE_TOP_K=5
