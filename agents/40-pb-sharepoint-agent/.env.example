# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
AZURE_PROJECT_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<foundry-account>/projects/<project-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=<model-deployment-name>

# SharePoint tool (required)
# Use full Foundry project connection ARM ID (least-privilege site-scoped read connection)
SHAREPOINT_CONNECTION_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.MachineLearningServices/workspaces/<workspace>/connections/<sharepoint-connection-name>
SHAREPOINT_AGENT_NAME=pb-sharepoint-agent

# Telemetry (optional)
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=<instrumentation-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<app-id>
OTEL_SERVICE_NAME=pb-sharepoint-agent
OTEL_SERVICE_VERSION=0.1.0
OTEL_CAPTURE_MESSAGE_CONTENT=true
