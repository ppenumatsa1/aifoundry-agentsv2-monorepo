# Azure AI Projects
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>

# Azure OpenAI (Responses API)
AZURE_OPENAI_ENDPOINT=https://<azure-openai-resource>.cognitiveservices.azure.com
AZURE_AI_MODEL_DEPLOYMENT_NAME=<model-deployment-name>
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# LLM-as-judge (Foundry evals API)
# Use a deployment in your Foundry project for judge (same as AZURE_AI_MODEL_DEPLOYMENT_NAME)

# Azure Monitor / App Insights
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=<instrumentation-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<app-id>
OTEL_CAPTURE_MESSAGE_CONTENT=true


# Agent settings
INVOICE_DATASET_NAME=invoices-dataset
INVOICE_VECTORSTORE_NAME=invoices-vectorstore
INVOICE_AGENT_NAME=pb-vectorstore-invoice-agent
INVOICE_TOP_K=5
