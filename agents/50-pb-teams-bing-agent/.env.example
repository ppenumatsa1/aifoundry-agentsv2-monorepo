# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
AZURE_PROJECT_RESOURCE_ID=/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.CognitiveServices/accounts/<foundry-account>/projects/<project-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Foundry published agent to invoke from Teams
FOUNDRY_AGENT_ID=pb-teams-bing-agent

# Teams / Microsoft 365 Agents SDK credentials
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_TENANT_ID=
# Use deployed bot endpoint (recommended):
# https://<aca-fqdn>/api/messages
BOT_ENDPOINT=
# TEAMS_APP_ID=

# Credential (optional for user-assigned Managed Identity)
# Local: az login
# ACA: system/user-assigned managed identity
# MANAGED_IDENTITY_CLIENT_ID=

# Runtime host settings
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# App Insights telemetry (optional; telemetry is enabled only when set)
APP_INSIGHTS_CONNECTION_STRING=
