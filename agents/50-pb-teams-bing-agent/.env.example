# Bot identity (Azure Bot Service)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=
MICROSOFT_APP_TYPE=SingleTenant

# Foundry endpoint used by runtime app (no secret required)
FOUNDRY_AGENT_ENDPOINT=

# Credential selection
# ACA runtime uses Managed Identity automatically.
# For local forcing MI flow:
# USE_MANAGED_IDENTITY=true
# MANAGED_IDENTITY_CLIENT_ID=<optional-user-assigned-mi-client-id>

# Local app host
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Foundry agent creation script
AZURE_AI_PROJECT_ENDPOINT=
FOUNDRY_AGENT_ID=pb-teams-bing-agent
