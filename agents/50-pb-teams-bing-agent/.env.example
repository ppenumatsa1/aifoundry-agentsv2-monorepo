# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_AGENT_ID=<foundry-agent-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=<model-deployment-name>
FOUNDRY_PUBLISHED_ACTIVITY_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>/applications/<application-name>/protocols/activityprotocol?api-version=2025-11-15-preview
# Optional override to avoid auto token acquisition via `az account get-access-token`
# FOUNDRY_AI_ACCESS_TOKEN=<bearer-token>
# Optional recipient id used in activity payload
# FOUNDRY_PUBLISHED_APP_ID=<application-name>
# Optional Web Search Preview tuning
# WEB_SEARCH_CONTEXT_SIZE=medium
# WEB_SEARCH_COUNTRY=US
# WEB_SEARCH_REGION=WA
# WEB_SEARCH_CITY=Seattle
# WEB_SEARCH_TIMEZONE=America/Los_Angeles
