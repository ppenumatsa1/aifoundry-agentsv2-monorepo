# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_AGENT_ID=<foundry-agent-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=<model-deployment-name>
# Optional Web Search Preview tuning
# WEB_SEARCH_CONTEXT_SIZE=medium
# WEB_SEARCH_COUNTRY=US
# WEB_SEARCH_REGION=WA
# WEB_SEARCH_CITY=Seattle
# WEB_SEARCH_TIMEZONE=America/Los_Angeles

# Microsoft 365 Agents SDK auth (preferred format)
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<app-id>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<app-password>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<tenant-id>

# Compatibility aliases (optional; app maps these to CONNECTIONS__... if needed)
MICROSOFT_APP_ID=<app-id>
MICROSOFT_APP_PASSWORD=<app-password>
MICROSOFT_APP_TENANT_ID=<tenant-id>
MICROSOFT_APP_TYPE=MultiTenant

# FastAPI host settings
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
