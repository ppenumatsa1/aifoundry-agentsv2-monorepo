# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=
PROJECT_ENDPOINT=

# Foundry Agent to invoke from Teams
FOUNDRY_AGENT_ID=pb-teams-bing-agent
AZURE_AI_MODEL_DEPLOYMENT_NAME=
# Optional Web Search Preview tuning
# WEB_SEARCH_CONTEXT_SIZE=medium
# WEB_SEARCH_COUNTRY=US
# WEB_SEARCH_REGION=WA
# WEB_SEARCH_CITY=Seattle
# WEB_SEARCH_TIMEZONE=America/Los_Angeles

# Teams / Microsoft 365 Agents SDK credentials
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=SingleTenant
MICROSOFT_APP_TENANT_ID=

# Credential selection (optional)
# ACA runtime uses Managed Identity automatically.
# USE_MANAGED_IDENTITY=true
# MANAGED_IDENTITY_CLIENT_ID=

# Local host settings
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
