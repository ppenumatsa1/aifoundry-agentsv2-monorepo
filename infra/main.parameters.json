{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "userPrincipalId": {
      "value": "${userPrincipalId}"
    },
    "existingFoundryName": {
      "value": "${existingFoundryName}"
    },
    "existingFoundryProjectName": {
      "value": "${existingFoundryProjectName}"
    },
    "m365AcrName": {
      "value": "${m365AcrName}"
    },
    "m365BotAppId": {
      "value": "${m365BotAppId}"
    },
    "m365BotTenantId": {
      "value": "${m365BotTenantId}"
    },
    "m365BotAppType": {
      "value": "${m365BotAppType}"
    },
    "m365BotName": {
      "value": "${m365BotName}"
    },
    "m365FoundryProjectEndpoint": {
      "value": "${m365FoundryProjectEndpoint}"
    },
    "m365LogAnalyticsWorkspaceResourceId": {
      "value": "${m365LogAnalyticsWorkspaceResourceId}"
    },
    "searchSkuName": {
      "value": "${searchSkuName}"
    },
    "textEmbedding3SmallCapacity": {
      "value": "${textEmbedding3SmallCapacity}"
    },
    "gpt4oCapacity": {
      "value": "${gpt4oCapacity}"
    },
    "gpt41MiniCapacity": {
      "value": "${gpt41MiniCapacity}"
    },
    "gpt5Capacity": {
      "value": "${gpt5Capacity}"
    },
    "textEmbedding3LargeCapacity": {
      "value": "${textEmbedding3LargeCapacity}"
    }
  }
}
