          "variables": {
            "useExistingAcr": "[not(empty(parameters('acrName')))]",
            "resolvedAcrName": "[toLower(if(empty(parameters('acrName')), take(replace(format('{0}tacr', parameters('namePrefix')), '-', ''), 50), parameters('acrName')))]",
            "resolvedAcaEnvironmentName": "[if(empty(parameters('acaEnvironmentName')), format('{0}-ace', parameters('namePrefix')), parameters('acaEnvironmentName'))]",
            "resolvedAcaAppName": "[if(empty(parameters('acaAppName')), format('{0}-teamsapp', parameters('namePrefix')), parameters('acaAppName'))]",
            "resolvedBotName": "[if(empty(parameters('botName')), format('{0}-bot', parameters('namePrefix')), parameters('botName'))]",
            "hasBotPassword": "[not(empty(parameters('botAppPassword')))]",
            "botPasswordSecret": "[if(variables('hasBotPassword'), createArray(createObject('name', 'ms-app-password', 'value', parameters('botAppPassword'))), createArray())]",
            "botPasswordEnv": "[if(variables('hasBotPassword'), createArray(createObject('name', 'MICROSOFT_APP_PASSWORD', 'secretRef', 'ms-app-password')), createArray())]",
            "acrResourceId": "[resourceId('Microsoft.ContainerRegistry/registries', variables('resolvedAcrName'))]"
          },
          "resources": [
            {
              "condition": "[not(variables('useExistingAcr'))]",
              "type": "Microsoft.ContainerRegistry/registries",
              "apiVersion": "2023-07-01",
              "name": "[variables('resolvedAcrName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Basic"
              },
              "properties": {
                "adminUserEnabled": false,
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.App/managedEnvironments",
              "apiVersion": "2024-03-01",
              "name": "[variables('resolvedAcaEnvironmentName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "appLogsConfiguration": {
                  "destination": "log-analytics",
                  "logAnalyticsConfiguration": {
                    "customerId": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', parameters('logAnalyticsWorkspaceSubscriptionId'), parameters('logAnalyticsWorkspaceResourceGroup')), 'Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2022-10-01').customerId]",
                    "sharedKey": "[listKeys(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', parameters('logAnalyticsWorkspaceSubscriptionId'), parameters('logAnalyticsWorkspaceResourceGroup')), 'Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), '2022-10-01').primarySharedKey]"
                  }
                }
              }
            },
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[variables('resolvedAcaAppName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('resolvedAcaEnvironmentName'))]",
                "configuration": {
                  "activeRevisionsMode": "Single",
                  "ingress": {
                    "external": true,
                    "targetPort": 8000,
                    "transport": "Auto"
                  },
                  "registries": [
                    {
                      "server": "[reference(variables('acrResourceId'), '2023-07-01').loginServer]",
                      "username": "[listCredentials(variables('acrResourceId'), '2023-07-01').username]",
                      "passwordSecretRef": "acr-password"
                    }
                  ],
                  "secrets": "[concat(variables('botPasswordSecret'), createArray(createObject('name', 'acr-password', 'value', listCredentials(variables('acrResourceId'), '2023-07-01').passwords[0].value)))]"
                },
                "template": {
                  "containers": [
                    {
                      "name": "[variables('resolvedAcaAppName')]",
                      "image": "[format('{0}/{1}:{2}', reference(variables('acrResourceId'), '2023-07-01').loginServer, parameters('imageRepository'), parameters('imageTag'))]",
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      },
                      "env": "[concat(createArray(createObject('name', 'MICROSOFT_APP_ID', 'value', parameters('botAppId')), createObject('name', 'MICROSOFT_APP_TENANT_ID', 'value', parameters('botTenantId')), createObject('name', 'MICROSOFT_APP_TYPE', 'value', parameters('botAppType')), createObject('name', 'AZURE_AI_PROJECT_ENDPOINT', 'value', parameters('foundryProjectEndpoint')), createObject('name', 'AZURE_AI_MODEL_DEPLOYMENT_NAME', 'value', parameters('foundryModelDeploymentName')), createObject('name', 'FOUNDRY_AGENT_ID', 'value', parameters('foundryAgentId'))), variables('botPasswordEnv'))]"
                    }
                  ],
                  "scale": {
                    "minReplicas": 1,
                    "maxReplicas": 1
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/managedEnvironments', variables('resolvedAcaEnvironmentName'))]"
              ]
            },
            {
              "condition": "[variables('useExistingAcr')]",
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('resolvedAcrName'))]",
              "name": "[guid(variables('acrResourceId'), resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), parameters('acrPullRoleDefinitionId'))]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), '2024-03-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', parameters('acrPullRoleDefinitionId'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName'))]"
              ]
            },
            {
              "condition": "[not(variables('useExistingAcr'))]",
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('resolvedAcrName'))]",
              "name": "[guid(variables('acrResourceId'), resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), parameters('acrPullRoleDefinitionId'))]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), '2024-03-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', parameters('acrPullRoleDefinitionId'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ContainerRegistry/registries', variables('resolvedAcrName'))]",
                "[resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName'))]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName'))]",
              "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryName')), resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), parameters('azureAiUserRoleDefinitionId'))]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), '2024-03-01', 'full').identity.principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', parameters('azureAiUserRoleDefinitionId'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName'))]"
              ]
            },
            {
              "type": "Microsoft.BotService/botServices",
              "apiVersion": "2022-09-15",
              "name": "[variables('resolvedBotName')]",
              "location": "global",
              "kind": "azurebot",
              "sku": {
                "name": "F0"
              },
              "tags": "[parameters('tags')]",
              "properties": {
                "displayName": "[variables('resolvedBotName')]",
                "endpoint": "[format('https://{0}/api/messages', reference(resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), '2024-03-01').configuration.ingress.fqdn)]",
                "msaAppId": "[parameters('botAppId')]",
                "msaAppTenantId": "[parameters('botTenantId')]",
                "msaAppType": "[parameters('botAppType')]",
                "publicNetworkAccess": "Enabled",
                "disableLocalAuth": false,
                "isStreamingSupported": false
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName'))]"
              ]
            }
          ],
          "outputs": {
            "acrId": {
              "type": "string",
              "value": "[variables('acrResourceId')]"
            },
            "acrName": {
              "type": "string",
              "value": "[variables('resolvedAcrName')]"
            },
            "acrLoginServer": {
              "type": "string",
              "value": "[reference(variables('acrResourceId'), '2023-07-01').loginServer]"
            },
            "acaEnvironmentId": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/managedEnvironments', variables('resolvedAcaEnvironmentName'))]"
            },
            "acaEnvironmentName": {
              "type": "string",
              "value": "[variables('resolvedAcaEnvironmentName')]"
            },
            "acaAppName": {
              "type": "string",
              "value": "[variables('resolvedAcaAppName')]"
            },
            "acaFqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), '2024-03-01').configuration.ingress.fqdn]"
            },
            "botName": {
              "type": "string",
              "value": "[variables('resolvedBotName')]"
            },
            "botEndpoint": {
              "type": "string",
              "value": "[format('https://{0}/api/messages', reference(resourceId('Microsoft.App/containerApps', variables('resolvedAcaAppName')), '2024-03-01').configuration.ingress.fqdn)]"
            }
          }
        }
      },
      "dependsOn": [
        "monitoring"
      ]
    }
  },
  "outputs": {
    "location": {
      "type": "string",
      "value": "[parameters('location')]"
    },
    "environmentName": {
      "type": "string",
      "value": "[parameters('environmentName')]"
    },
    "foundryId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', variables('foundryName'))]"
    },
    "foundryName": {
      "type": "string",
      "value": "[variables('foundryName')]"
    },
    "foundryProjectName": {
      "type": "string",
      "value": "[variables('foundryProjectName')]"
    },
    "foundryProjectPrincipalId": {
      "type": "string",
      "value": "[reference('foundryProject', '2025-04-01-preview', 'full').identity.principalId]"
    },
    "appInsightsConnectionString": {
      "type": "securestring",
      "value": "[listOutputsWithSecureValues('monitoring', '2025-04-01').appInsightsConnectionString]"
    },
    "logAnalyticsWorkspaceResourceId": {
      "type": "string",
      "value": "[reference('monitoring').outputs.logAnalyticsWorkspaceId.value]"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "value": "[reference('monitoring').outputs.logAnalyticsWorkspaceName.value]"
    },
    "searchServiceName": {
      "type": "string",
      "value": "[reference('aiSearch').outputs.searchName.value]"
    },
    "searchServiceId": {
      "type": "string",
      "value": "[reference('aiSearch').outputs.searchId.value]"
    },
    "searchEndpoint": {
      "type": "string",
      "value": "[reference('aiSearch').outputs.searchEndpoint.value]"
    },
    "searchServicePrincipalId": {
      "type": "string",
      "value": "[reference('aiSearch').outputs.searchPrincipalId.value]"
    }
  }
}